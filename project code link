        "    model.eval()\n",
        "    url = \"https://raw.githubusercontent.com/pytorch/hub/master/imagenet_classes.txt\"\n",
        "    categories = [line.decode(\"utf-8\").strip() for line in urllib.request.urlopen(url)]\n",
        "    return model, categories, device\n",
